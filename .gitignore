# ─── Node.js ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm

# ─── Environment / Secrets (NEVER commit these) ─────
.env
.env.*
!.env.example
*.local

# ─── Build output ────────────────────────────────────
dist/
build/
.output/
out/

# ─── Vite cache ──────────────────────────────────────
.vite/

# ─── OS files ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── IDE / Editor ────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.user
*.swp
*.swo

# ─── Logs ────────────────────────────────────────────
logs/
*.log

# ─── Temp / Debug ────────────────────────────────────
tmp/
temp/
*.tmp

# ─── Optional: keep these if using turbo/nx ──────────
.turbo/
.nx/

# ─── Test coverage ───────────────────────────────────
coverage/
.nyc_output/
