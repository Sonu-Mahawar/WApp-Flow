# WhatsApp Platform — Dashboard Environment Config
# Copy to .env (without the .example) and set real values

# ─── API Configuration ─────────────────────────────────────────────────────────
# Development: leave empty (Vite proxy in vite.config.js handles /api → localhost:3001)
# Production (Hostinger): set to your domain:
VITE_API_URL=

# ─── Webhook URL ──────────────────────────────────────────────────────────────
# Development: will auto-detect from vite proxy
# Production: your domain without trailing slash
VITE_WEBHOOK_URL=https://digitalatlus.in

# ─── App Branding ─────────────────────────────────────────────────────────────
VITE_APP_NAME=DigitalAtlus WhatsApp Platform
VITE_APP_URL=https://digitalatlus.in

# ─── Feature Flags ────────────────────────────────────────────────────────────
VITE_ENABLE_AI_CHATBOT=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_CAMPAIGNS=true
