PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/whatsapp_platform

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Upstash Redis (free tier)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# WhatsApp Business API (Meta)
WABA_ACCESS_TOKEN=your_meta_access_token
WABA_PHONE_NUMBER_ID=your_phone_number_id
WABA_BUSINESS_ACCOUNT_ID=your_waba_business_account_id
WABA_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Internal service URLs (for Hostinger deployment, same server)
MESSAGING_SERVICE_URL=http://localhost:3002
AUTOMATION_ENGINE_URL=http://localhost:3003
AI_SERVICE_URL=http://localhost:3004
ANALYTICS_SERVICE_URL=http://localhost:3005
WEBHOOK_HANDLER_URL=http://localhost:3006

# Upstash QStash (for queuing)
QSTASH_TOKEN=your_qstash_token
QSTASH_CURRENT_SIGNING_KEY=your_signing_key
QSTASH_NEXT_SIGNING_KEY=your_next_signing_key

# Frontend URL
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# Shopify
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret

# Stripe / Razorpay
STRIPE_SECRET_KEY=your_stripe_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
